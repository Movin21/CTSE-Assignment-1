{
    "name": "notification-service",
    "version": "1.0.0",
    "description": "Notification Microservice with Socket.io real-time push",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "ts-node-dev --respawn src/index.ts",
        "db:migrate": "prisma migrate deploy",
        "db:generate": "prisma generate"
    },
    "dependencies": {
        "amqplib": "^0.10.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.18.2",
        "morgan": "^1.10.0",
        "socket.io": "^4.7.4",
        "@prisma/client": "^5.10.2"
    },
    "devDependencies": {
        "@types/amqplib": "^0.10.4",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/morgan": "^1.9.9",
        "@types/node": "^20.11.17",
        "prisma": "^5.10.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    }
}